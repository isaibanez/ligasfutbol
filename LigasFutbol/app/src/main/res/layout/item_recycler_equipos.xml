<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:id="@+id/escudoEquipoRecycler"
        />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@+id/escudoEquipoRecycler"
        tools:layout_editor_absoluteY="16dp"
        tools:text="Nombre del equipo"
        android:id="@+id/nombreEquipoRecycler"
        />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Añadir a favoritos"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toEndOf="@+id/escudoEquipoRecycler"
        app:layout_constraintTop_toBottomOf="@+id/nombreEquipoRecycler"
        android:id="@+id/btnAnadirFavoritosRecycler"
        />


</androidx.constraintlayout.widget.ConstraintLayout>