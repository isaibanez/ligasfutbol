<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph.xml"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/registroFragment"
        android:name="com.example.ligasfutbol.fragment.RegistroFragment"
        android:label="RegistroFragment"
        android:layout="@layout/fragment_registro">
        <action
            android:id="@+id/action_registroFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.ligasfutbol.fragment.MainFragment"
        android:label="MainFragment"
        android:layout="@layout/fragment_main">
        <action
            android:id="@+id/action_mainFragment_to_registroFragment"
            app:destination="@id/registroFragment" />
        <action
            android:id="@+id/action_mainFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.ligasfutbol.fragment.HomeFragment"
        android:label="HomeFragment" >
        <action
            android:id="@+id/action_homeFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_homeFragment_to_equiposFragment"
            app:destination="@id/equiposFragment" />
        <action
            android:id="@+id/action_homeFragment_to_favoritosFragment"
            app:destination="@id/favoritosFragment" />
    </fragment>
    <fragment
        android:id="@+id/equiposFragment"
        android:name="com.example.ligasfutbol.fragment.EquiposFragment"
        android:label="EquiposFragment" >
        <action
            android:id="@+id/action_equiposFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_equiposFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_equiposFragment_to_favoritosFragment"
            app:destination="@id/favoritosFragment" />
    </fragment>
    <fragment
        android:id="@+id/favoritosFragment"
        android:name="com.example.ligasfutbol.fragment.FavoritosFragment"
        android:label="FavoritosFragment" >
        <action
            android:id="@+id/action_favoritosFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_favoritosFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>
</navigation>